{
  "name": "web-admx-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev --host",
    "build": "pnpm run build:data && astro build",
    "build:data": "tsx scripts/fetch-admx.ts && tsx scripts/parse-ddf.ts && tsx scripts/enrich-graph.ts && tsx scripts/build-policy-data.ts",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/vue": "^5.1.4",
    "astro": "^5.18.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "fflate": "^0.8.2",
    "happy-dom": "^20.8.8",
    "minisearch": "^7.2.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}