{
  "name": "web-admx-tool",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "astro dev --host",
    "build": "pnpm run build:data && astro build",
    "build:data": "tsx scripts/fetch-admx.ts && tsx scripts/parse-ddf.ts && tsx scripts/enrich-graph.ts",
    "preview": "astro preview",
    "screenshot": "node scripts/screenshot.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vue": "^7.0.0",
    "astro": "^7.0.0",
    "vue": "^3.5.34",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "25.9.5",
    "fflate": "0.8.3",
    "minisearch": "7.2.0",
    "playwright": "1.61.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}