---
export const prerender = false

const params = Astro.url.searchParams
const policy = params.get('Policy')
const lang = (params.get('Language') || Astro.preferredLocale || 'en-us').toLowerCase()

if (policy?.includes('::')) {
  const sep = policy.indexOf('::')
  return Astro.redirect(`/${lang}/policy/${policy.slice(0, sep)}/${policy.slice(sep + 2)}`)
}
return Astro.redirect(`/${lang}/`)
---
