---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { resolve } from 'path';
import { getLanguagePaths } from '@/admxUtils';
export const getStaticPaths = getLanguagePaths;

const { lang } = Astro.params;
const stats = JSON.parse(readFileSync(resolve(process.cwd(), 'public/data/stats.json'), 'utf8'));
const statItems = [
  { value: stats.fileCount, label: 'ADMX Files' },
  { value: stats.policyCount, label: 'Policies' },
  { value: stats.categoryCount, label: 'Categories' },
  { value: stats.languageCount, label: 'Languages' },
];
---

<BaseLayout lang={lang}>
  <div class="max-w-4xl p-6">
    <h1 class="text-3xl font-bold mb-2 dark:text-white">ADMX Viewer</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">
      Browse, search, and inspect Group Policy settings from ADMX/ADML files.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      {statItems.map(item => (
        <div class="bg-white dark:bg-gray-800 p-4 rounded-lg border border-gray-200 dark:border-gray-700">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{item.value}</div>
          <div class="text-sm text-gray-500 dark:text-gray-400">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
