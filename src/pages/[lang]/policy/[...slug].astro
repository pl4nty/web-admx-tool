---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPolicies = await getCollection('policies');
  const paths: any[] = [];
  const seen = new Set<string>();

  for (const entry of allPolicies) {
    const { lang, namespace, fileSlug, availableLangs } = entry.data;
    const routeSlug = `${namespace}/${entry.data.name}`;
    const key = `${lang}:${routeSlug}`;
    if (seen.has(key)) continue;
    seen.add(key);
    const props = { policy: entry.data, namespace, fileSlug, lang, availableLangs };
    paths.push({ params: { lang, slug: routeSlug }, props });

    if (fileSlug !== namespace) {
      const aliasKey = `${lang}:${fileSlug}/${entry.data.name}`;
      if (!seen.has(aliasKey)) {
        seen.add(aliasKey);
        paths.push({ params: { lang, slug: `${fileSlug}/${entry.data.name}` }, props });
      }
    }
  }
  return paths;
}

const { policy, namespace, fileSlug, lang, availableLangs } = Astro.props;
const title = `${policy.displayName || policy.name} - ADMX Viewer`;

const presentationByRef = new Map(
  (policy.presentationElements || []).filter((el: any) => el?.refId).map((el: any) => [el.refId, el])
)
const presentationNotes = (policy.presentationElements || []).filter(
  (el: any) => el?.type === 'text' && el?.label && !el?.refId
)
const hasElements = policy.elements?.length > 0
const hasExplicitValues = Boolean(policy.enabledValue || policy.disabledValue)
const showStateFallback = !hasElements && !hasExplicitValues && (policy.key || policy.valueName)

const fmtVal = (val: any) => !val ? 'Not set' : val.type === 'decimal' ? String(val.value) : val.type === 'string' ? String(val.value || '') : val.type === 'delete' ? 'Delete value' : String(val)
const elemLabel = (elem: any) => presentationByRef.get(elem?.id)?.label || elem?.label || elem?.id || 'Value'
const elemDefault = (elem: any) => { const pres = presentationByRef.get(elem?.id); return pres?.defaultValue != null ? String(pres.defaultValue) : null }
const linkify = (text: string) => String(text || '').replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" style="color:#0ea5e9;text-decoration:underline;text-underline-offset:2px;" target="_blank" rel="noopener noreferrer">$1</a>')
---

<BaseLayout title={title} showSidebar={true} lang={lang}>
  <div class="max-w-5xl w-full p-6" data-pagefind-body
    data-pagefind-meta={`namespace:${namespace},class:${policy.class},fileSlug:${fileSlug},policyName:${policy.name},displayName:${policy.displayName || policy.name},category:${policy.parentCategory || ''}`}>

    {lang !== 'en-us' && (
      <div class="mb-4 text-xs text-gray-500 dark:text-gray-400 flex items-center gap-2">
        <span class="inline-flex items-center px-2 py-0.5 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded">{lang.toUpperCase()}</span>
        <a href={`/en-us/policy/${namespace}/${policy.name}`} class="text-blue-600 dark:text-blue-400 hover:underline">View in English</a>
      </div>
    )}

    <div class="mb-6">
      <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-2">
        <span>{namespace}</span><span>&bull;</span>
        <span class={policy.class === 'Machine' ? 'text-blue-600' : policy.class === 'User' ? 'text-green-600' : 'text-purple-600'}>{policy.class}</span>
      </div>
      <h1 class="text-3xl font-bold mb-3 dark:text-white break-words">{policy.displayName || policy.name}</h1>
      {policy.explainText && <div class="prose dark:prose-invert max-w-none mb-6 text-gray-700 dark:text-gray-300"><p class="whitespace-pre-wrap" set:html={linkify(policy.explainText)} /></div>}
    </div>

    <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6 transition-colors duration-0">
      <h2 class="text-lg font-semibold mb-4 dark:text-white">Policy Details</h2>
      <dl class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="font-medium text-gray-500 dark:text-gray-400">Policy Name</dt>
          <dd class="text-gray-900 dark:text-white font-mono">{policy.name}</dd>
        </div>
        {policy.key && <div class="md:col-span-2"><dt class="font-medium text-gray-500 dark:text-gray-400">Registry Key</dt><dd class="text-gray-900 dark:text-white font-mono break-all">{policy.key}</dd></div>}
        {policy.valueName && <div><dt class="font-medium text-gray-500 dark:text-gray-400">Value Name</dt><dd class="text-gray-900 dark:text-white font-mono">{policy.valueName}</dd></div>}
        {policy.supportedOn && <div><dt class="font-medium text-gray-500 dark:text-gray-400">Supported On</dt><dd class="text-gray-900 dark:text-white">{policy.supportedOn}</dd></div>}

        {policy.csp?.uri && (
          <div class="md:col-span-2">
            <dt class="font-medium text-gray-500 dark:text-gray-400">OMA-URI (CSP)</dt>
            <dd class="text-gray-900 dark:text-white">
              <div class="font-mono break-all text-sm">{policy.csp.uri}</div>
              {policy.csp.description && <div class="mt-1 text-sm text-gray-600 dark:text-gray-300" set:html={linkify(policy.csp.description)} />}
              <div class="mt-3 space-y-1">
                {[['Access Types', policy.csp.accessTypes], ['OS Build Version', policy.csp.osBuildVersion], ['CSP Version', policy.csp.cspVersion], ['Conflict Resolution', policy.csp.conflictResolution]].filter(([, v]) => v).map(([label, value]) => (
                  <div class="text-sm"><span class="font-medium text-gray-600 dark:text-gray-400">{label}:</span><span class="text-gray-700 dark:text-gray-300 ml-1">{value}</span></div>
                ))}
                {policy.csp.editionAllowList?.length > 0 && (
                  <div class="text-sm">
                    <span class="font-medium text-gray-600 dark:text-gray-400">Allowed Editions:</span>
                    <div class="flex flex-wrap gap-1 mt-1">
                      {policy.csp.editionAllowList.map((ed: string) => <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">{ed}</span>)}
                    </div>
                  </div>
                )}
              </div>
            </dd>
          </div>
        )}

        {policy.catalog?.id && (() => {
          const scope = policy.catalog.scopeAvailability === 'both' ? 'Device & User' : policy.class === 'Machine' ? 'Device only' : 'User only'
          const color = policy.catalog.scopeAvailability === 'both' ? 'purple' : policy.class === 'Machine' ? 'blue' : 'green'
          return (
            <div>
              <dt class="font-medium text-gray-500 dark:text-gray-400">Settings Catalog</dt>
              <dd class="flex items-center gap-2 flex-wrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">Available</span>
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-${color}-100 text-${color}-800 dark:bg-${color}-900 dark:text-${color}-200`}>{scope}</span>
              </dd>
            </div>
          )
        })()}

        {(policy.enabledValue || policy.disabledValue) && (
          <div class="md:col-span-2">
            <dt class="font-medium text-gray-500 dark:text-gray-400">Policy State Values</dt>
            <dd class="text-sm text-gray-700 dark:text-gray-300">
              {policy.enabledValue && <div>Enabled: <span class="font-mono">{fmtVal(policy.enabledValue)}</span></div>}
              {policy.disabledValue && <div>Disabled: <span class="font-mono">{fmtVal(policy.disabledValue)}</span></div>}
            </dd>
          </div>
        )}

        <div>
          <dt class="font-medium text-gray-500 dark:text-gray-400">Available Languages</dt>
          <dd class="flex flex-wrap gap-1 mt-1">
            {availableLangs.map((availLang: string) => (
              <a href={`/${availLang}/policy/${namespace}/${policy.name}`}
                class:list={['inline-block px-1.5 py-0.5 text-xs rounded', availLang === lang ? 'bg-blue-600 text-white' : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900']}>{availLang}</a>
            ))}
          </dd>
        </div>
      </dl>
    </div>

    {showStateFallback && (
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6 mb-6">
        <h2 class="text-lg font-semibold mb-2 dark:text-white">Supported Values</h2>
        <p class="text-sm text-gray-600 dark:text-gray-300">Simple Enabled/Disabled toggle controlling whether the value exists under the configured registry key.</p>
      </div>
    )}

    {hasElements && (
      <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg p-6">
        <h2 class="text-lg font-semibold mb-4 dark:text-white">Configuration Elements</h2>
        {presentationNotes.length > 0 && <div class="mb-4 text-sm text-gray-600 dark:text-gray-300">{presentationNotes.map((n: any) => <p class="mb-2">{n.label}</p>)}</div>}
        <div class="space-y-4">
          {policy.elements.map((elem: any) => (
            <div class="border-t border-gray-200 dark:border-gray-700 pt-4 first:border-t-0 first:pt-0">
              <h3 class="font-medium text-gray-900 dark:text-white mb-1 break-words">{elemLabel(elem)}</h3>
              {elem.type && <p class="text-sm text-gray-500 dark:text-gray-400">Type: <span class="font-mono">{elem.type}</span></p>}
              {elemDefault(elem) && <p class="text-sm text-gray-500 dark:text-gray-400">Default: <span class="font-mono">{elemDefault(elem)}</span></p>}

              {elem.type === 'enum' && elem.items?.length > 0 && (
                <div class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                  <div class="font-medium text-gray-700 dark:text-gray-200">Allowed Values</div>
                  <ul class="mt-1 space-y-1">
                    {elem.items.map((item: any) => (
                      <li class="flex flex-wrap gap-2">
                        <span class="font-mono text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-700">{fmtVal(item.value)}</span>
                        <span class="text-sm">{item.displayName || 'Option'}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {elem.type === 'boolean' && (
                <div class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                  <div class="flex flex-wrap gap-2"><span class="font-medium">True:</span><span class="font-mono">{fmtVal(elem.trueValue)}</span></div>
                  <div class="flex flex-wrap gap-2"><span class="font-medium">False:</span><span class="font-mono">{fmtVal(elem.falseValue)}</span></div>
                </div>
              )}
              {(elem.type === 'decimal' || elem.type === 'longDecimal') && (
                <div class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                  {elem.minValue !== undefined && <div>Min: <span class="font-mono">{elem.minValue}</span></div>}
                  {elem.maxValue !== undefined && <div>Max: <span class="font-mono">{elem.maxValue}</span></div>}
                </div>
              )}
              {(elem.type === 'text' || elem.type === 'multiText') && (
                <div class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                  {elem.maxLength !== undefined && <div>Max length: <span class="font-mono">{elem.maxLength}</span></div>}
                  {elem.expandable !== undefined && <div>Expandable: <span class="font-mono">{String(elem.expandable)}</span></div>}
                </div>
              )}
              {elem.type === 'list' && (
                <div class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                  {elem.explicitValue !== undefined && <div>Explicit values: <span class="font-mono">{String(elem.explicitValue)}</span></div>}
                  {elem.additive !== undefined && <div>Additive: <span class="font-mono">{String(elem.additive)}</span></div>}
                  {elem.valuePrefix && <div>Value prefix: <span class="font-mono">{elem.valuePrefix}</span></div>}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>

  <script define:vars={{ namespace, policyName: policy.name, availableLangs }}>
    window.__admxPolicyMeta = {
      namespace,
      policyName,
      availableLangs,
    }
    sessionStorage.setItem('admx:expand-target', `${namespace}::${policyName}`)
  </script>
</BaseLayout>
