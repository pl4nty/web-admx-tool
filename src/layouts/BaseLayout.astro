---
import Sidebar from '@/components/Sidebar.vue';
import '@/style.css';

interface Props {
title?: string;
showSidebar?: boolean;
lang?: string;
}

const { title = 'ADMX Viewer', showSidebar = true, lang = 'en-us' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang.split('-')[0]}>

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="color-scheme" content="light dark">
  <link rel="icon" href="/favicon.ico" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <title>{title}</title>
  <style>
    html, body {
      background-color: rgb(249 250 251);
    }
    @media (prefers-color-scheme: dark) {
      html, body {
        background-color: rgb(17 24 39);
        color-scheme: dark;
      }
    }
    html.dark, html.dark body {
      background-color: rgb(17 24 39);
      color-scheme: dark;
    }
  </style>
  <script>
    const t = localStorage.getItem('theme')
    if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark')
      document.documentElement.style.backgroundColor = 'rgb(17 24 39)'
    } else { document.documentElement.style.backgroundColor = 'rgb(249 250 251)' }
  </script>
</head>

<body class="transition-colors duration-0">
  <div class="admx-shell min-h-screen bg-gray-50 dark:bg-gray-900 overflow-x-hidden transition-colors duration-0">
    <!-- Header -->
    <header id="main-header" class="sticky top-0 z-40 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 transition-colors duration-0">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 px-4 py-2.5 md:h-14 md:flex-nowrap md:py-0 md:gap-x-4">
        <button id="sidebar-toggle"
          class="shrink-0 lg:hidden p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700"
          aria-label="Toggle sidebar">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <a href={`/${lang}/`}
          class="shrink-0 flex items-center gap-2 font-bold text-lg text-gray-900 dark:text-white no-underline hover:text-gray-700 dark:hover:text-gray-100 transition-colors">
          <img src="/favicon.ico" alt="ADMX Viewer" class="w-6 h-6" />
          <span class="hidden sm:inline text-gray-900 dark:text-white">ADMX Viewer</span>
        </a>

        <div class="order-last w-full md:order-none md:flex-1 md:max-w-xl" id="search-container">
          <form id="header-search-form" class="relative">
            <input id="header-search-input" type="search" placeholder="Search policies..."
              class="w-full text-sm bg-gray-50 border border-gray-300 text-gray-900 rounded-lg px-3 py-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white dark:placeholder-gray-400" />
            <div id="header-search-dropdown"
              class="absolute mt-1 w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg hidden max-h-96 overflow-y-auto z-50">
            </div>
          </form>
        </div>

        <div class="shrink-0 flex items-center gap-2 ml-auto">
          <select id="scope-selector"
            class="text-xs sm:text-sm border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-2 sm:px-2.5 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 cursor-pointer">
            <option value="all">All</option>
            <option value="Machine">Computer</option>
            <option value="User">User</option>
          </select>

          <select id="lang-selector"
            class="text-xs sm:text-sm max-w-[7rem] border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-2 sm:px-2.5 py-1.5 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 cursor-pointer">
            <!-- Will be populated by JS -->
          </select>

          <button id="theme-toggle"
            class="shrink-0 p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-colors"
            title="Toggle dark mode">
            <svg id="theme-icon-dark" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
            </svg>
            <svg id="theme-icon-light" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd"
                d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
                clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Sidebar -->
    {showSidebar && (
    <>
      <div class="admx-sidebar-overlay lg:hidden" id="sidebar-overlay"></div>
      <aside id="admx-sidebar"
        class="admx-sidebar fixed left-0 z-30 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 overflow-y-auto"
        style="top: var(--header-height, 3.5rem); height: calc(100vh - var(--header-height, 3.5rem))">
        <div id="sidebar-resize-handle" class="admx-sidebar-handle" title="Resize sidebar"></div>
        <Sidebar lang={lang} client:load />
      </aside>
    </>
    )}

    <!-- Main content -->
    <main class="admx-main">
      <slot />
    </main>
  </div>

  <script>
    import MiniSearch from 'minisearch'
    import { MINISEARCH_OPTS } from '../searchConfig'
    import { policyUrl } from '../policyUrl'

    const $ = (id: string) => document.getElementById(id)
    const urlLang = () => window.location.pathname.match(/^\/([a-z]{2}-[a-z0-9]{2,4})\//)?.[1] || 'en-us'

    // Theme
    const applyTheme = (isDark: boolean) => {
      document.documentElement.classList.toggle('dark', isDark)
      const bg = isDark ? 'rgb(17 24 39)' : 'rgb(249 250 251)'
      document.documentElement.style.backgroundColor = bg
      document.body.style.backgroundColor = bg
      localStorage.setItem('theme', isDark ? 'dark' : 'light')
      document.cookie = `theme=${isDark ? 'dark' : 'light'}; path=/; max-age=31536000; SameSite=Lax`
      $('theme-icon-dark')?.classList.toggle('hidden', isDark)
      $('theme-icon-light')?.classList.toggle('hidden', !isDark)
    }
    const saved = localStorage.getItem('theme')
    if (saved) applyTheme(saved === 'dark')
    $('theme-icon-dark')?.classList.toggle('hidden', document.documentElement.classList.contains('dark'))
    $('theme-icon-light')?.classList.toggle('hidden', !document.documentElement.classList.contains('dark'))
    $('theme-toggle')?.addEventListener('click', () => applyTheme(!document.documentElement.classList.contains('dark')))

    // Track header height for sidebar positioning
    const header = document.getElementById('main-header')
    if (header) {
      const updateHeaderHeight = () =>
        document.documentElement.style.setProperty('--header-height', `${header.offsetHeight}px`)
      updateHeaderHeight()
      new ResizeObserver(updateHeaderHeight).observe(header)
    }

    // Sidebar toggle
    $('sidebar-toggle')?.addEventListener('click', () => document.body.classList.toggle('sidebar-open'))
    $('sidebar-overlay')?.addEventListener('click', () => document.body.classList.remove('sidebar-open'))
    $('admx-sidebar')?.addEventListener('click', (e) => {
      if (window.innerWidth < 1024 && (e.target as Element)?.closest?.('a'))
        document.body.classList.remove('sidebar-open')
    })

    // Sidebar resize
    const storedWidth = localStorage.getItem('sidebar-width')
    if (storedWidth) document.documentElement.style.setProperty('--sidebar-width', storedWidth)
    let resizing = false
    const onMove = (e: PointerEvent) => {
      if (!resizing) return
      const v = `${Math.min(Math.max(e.clientX, 240), 520)}px`
      document.documentElement.style.setProperty('--sidebar-width', v)
      localStorage.setItem('sidebar-width', v)
    }
    const onUp = () => { resizing = false; document.body.classList.remove('sidebar-resizing'); window.removeEventListener('pointermove', onMove); window.removeEventListener('pointerup', onUp) }
    $('sidebar-resize-handle')?.addEventListener('pointerdown', (e) => {
      if (window.innerWidth < 1024) return
      resizing = true; document.body.classList.add('sidebar-resizing'); e.preventDefault()
      window.addEventListener('pointermove', onMove); window.addEventListener('pointerup', onUp)
    })

    // Scope selector
    const scopeEl = $('scope-selector') as HTMLSelectElement | null
    if (scopeEl) {
      scopeEl.value = localStorage.getItem('scope') || 'all'
      scopeEl.addEventListener('change', () => {
        localStorage.setItem('scope', scopeEl.value)
        window.dispatchEvent(new CustomEvent('admx:scope-changed', { detail: scopeEl.value }))
      })
    }

    // Flash notice
    const flash = sessionStorage.getItem('admx:notice')
    if (flash) {
      sessionStorage.removeItem('admx:notice')
      const el = document.createElement('div')
      el.className = 'fixed top-16 right-4 z-50 max-w-sm rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-sm text-amber-900 shadow dark:border-amber-700 dark:bg-amber-900/30 dark:text-amber-200'
      el.textContent = flash
      document.body.appendChild(el)
      setTimeout(() => el.remove(), 4200)
    }

    // Language selector
    fetch('/data/languages.json').then(r => r.json()).then((langs: string[]) => {
      const sel = $('lang-selector') as HTMLSelectElement | null
      if (!sel) return
      const cur = urlLang()
      localStorage.setItem('lang', cur)
      for (const lang of langs) {
        const opt = document.createElement('option')
        opt.value = lang; opt.selected = lang === cur
        try {
          const displayName = new Intl.DisplayNames([lang], { type: 'language' }).of(lang)
          opt.textContent = displayName && displayName !== lang ? displayName.charAt(0).toUpperCase() + displayName.slice(1) : lang.toUpperCase()
        } catch { opt.textContent = lang.toUpperCase() }
        sel.appendChild(opt)
      }
      sel.addEventListener('change', () => {
        const newLang = sel.value
        localStorage.setItem('lang', newLang)
        const meta = (window as any).__admxPolicyMeta
        if (meta?.availableLangs && !meta.availableLangs.includes(newLang)) {
          sessionStorage.setItem('admx:notice', `No ${newLang.toUpperCase()} translation for this policy. Redirected to en-US.`)
          window.location.assign(`/en-us/policy/${meta.namespace}/${meta.policyName}`)
          return
        }
        const langMatch = window.location.pathname.match(/^\/([a-z]{2}-[a-z0-9]{2,4})\//) 
        window.location.assign(langMatch ? window.location.pathname.replace(langMatch[0], `/${newLang}/`) + window.location.search : `/${newLang}/`)
      })
    })

    // Header search autocomplete
    const searchForm = $('header-search-form'), searchInput = $('header-search-input') as HTMLInputElement | null, dropdown = $('header-search-dropdown')
    let searchIndex: MiniSearch | null = null

    if (searchForm && searchInput && dropdown) {
      const initialQuery = new URL(window.location.href).searchParams.get('q')
      if (initialQuery) searchInput.value = initialQuery

      fetch(`/data/search-${urlLang()}.json`).then(r => r.ok ? r.json() : null).then(data => {
        if (data) searchIndex = MiniSearch.loadJS(data, MINISEARCH_OPTS)
      }).catch(() => {})

      const close = () => { dropdown!.classList.add('hidden'); dropdown!.innerHTML = '' }
      const escapeHtml = (text: string) => text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;')

      const render = () => {
        const query = searchInput!.value.trim()
        if (!query || !searchIndex) { close(); return }
        const hits = searchIndex.search(query, { limit: 8 })
        if (!hits.length) { close(); return }
        dropdown!.innerHTML = hits.map(hit => {
          const ns = escapeHtml(hit.namespace || ''), name = escapeHtml(hit.name || '')
          return `<button type="button" class="admx-search-item w-full text-left px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-700 border-b last:border-b-0 border-gray-100 dark:border-gray-700" data-namespace="${ns}" data-name="${name}"><div class="text-sm text-gray-900 dark:text-white truncate">${escapeHtml(hit.displayName || hit.name || '')}</div><div class="text-xs text-gray-500 dark:text-gray-400 truncate">${escapeHtml(hit.fileSlug || hit.namespace || '')}</div></button>`
        }).join('')
        dropdown!.classList.remove('hidden')
        dropdown!.querySelectorAll('.admx-search-item').forEach(el => {
          el.addEventListener('click', () => {
            const ns = el.getAttribute('data-namespace')!, name = el.getAttribute('data-name')!
            const picked = hits.find(hit => hit.namespace === ns && hit.name === name)
            if (!picked) return
            const langs: string[] = picked.availableLangs || [], lang = urlLang()
            sessionStorage.setItem('admx:expand-target', `${ns}::${name}`)
            if (!langs.includes(lang)) sessionStorage.setItem('admx:notice', `No ${lang.toUpperCase()} translation for this policy. Redirected to English.`)
            window.location.assign(policyUrl(ns, nm, langs, lang))
          })
        })
      }

      searchInput.addEventListener('input', render)
      searchInput.addEventListener('focus', render)
      document.addEventListener('click', (e) => { if (!searchForm.contains(e.target as Node)) close() })
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault(); close()
        const query = searchInput.value.trim()
        window.location.assign(`/${urlLang()}/search${query ? `?q=${encodeURIComponent(query)}` : ''}`)
      })
    }
  </script>
</body>

</html>