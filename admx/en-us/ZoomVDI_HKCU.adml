        <decimalTextBox refId="AudioAECLevel_Part" defaultValue="1" spinStep="1">Set audio AEC level</decimalTextBox>
      </presentation>
      <presentation id="SortBuddyMaxCount_Policy">
        <decimalTextBox refId="SortBuddyMaxCount_Part" spinStep="1">Set sort buddy max count</decimalTextBox>
      </presentation>
      <presentation id="PingServerFromThinClient_Policy" />
      <presentation id="EnableDifferentVersionTip_Policy" />
      <presentation id="ServiceUnavailableTipMsg_Policy">
        <textBox refId="ServiceUnavailableTipMsg_Part">
          <label>Set service unavailable tip message</label>
        </textBox>
      </presentation>
      <presentation id="FallbackModeTipMsg_Policy">
        <textBox refId="FallbackModeTipMsg_Part">
          <label>Set fallback mode tip message</label>
        </textBox>
      </presentation>
      <presentation id="IncompatibleTipMsg_Policy">
        <textBox refId="IncompatibleTipMsg_Part">
          <label>Set incompatible tip message</label>
        </textBox>
      </presentation>
      <presentation id="MinPluginVersion_Policy">
        <textBox refId="MinPluginVersion_Part">
          <label>Set min plugin version</label>
        </textBox>
      </presentation>
      <presentation id="DisableWallView7x7_Policy" />
      <presentation id="ForceWallView3x3_Policy" />
      <presentation id="AllowPluginDSCPMarking_Policy" />
      <presentation id="DisableShareOffload_Policy" />
      <presentation id="EnableShareAudioSound_Policy" />
      <presentation id="EnableOptimizeForVideo_Policy" />
      <presentation id="EnableWMIProvider_Policy" />
      <presentation id="DSCPValueForAudio_Policy">
        <decimalTextBox refId="DSCPValueForAudio_Part" spinStep="1">DSCP value for audio</decimalTextBox>
      </presentation>
      <presentation id="DSCPValueForVideo_Policy">
        <decimalTextBox refId="DSCPValueForVideo_Part" spinStep="1">DSCP value for video</decimalTextBox>
      </presentation>
      <presentation id="GPOBandwidthOverrideWeb_Policy">
        <decimalTextBox refId="GPOBandwidthOverrideWeb_Part" spinStep="1">GPO bandwidth override web</decimalTextBox>
      </presentation>
      <presentation id="DisableMMRDirect_Phone_Policy" />
      <presentation id="DisableUDPBridge_Phone_Policy" />
      <presentation id="DisableChannelBridge_Phone_Policy" />
      <presentation id="DisableVDIToolFileTransfer_Policy" />
      <presentation id="CheckHdxMediaOptimization_Policy" />
      <presentation id="EnableVDIPluginAutoUpgrade_Policy" />
      <presentation id="AutoUpdatePluginVersion_Policy">
